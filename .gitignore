# =============================================================================
# .gitignore — Medical Transcriber
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# --- Virtual environments ---
.venv/
venv/
env/
.uv/

# --- Environment variables (secrets, API keys) ---
.env
.env.local
.env.production

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# --- Streamlit ---
.streamlit/secrets.toml

# --- Downloaded models (can be large) ---
*.bin
*.pt
*.onnx
models/

# --- Temporary audio files ---
/tmp/medical_audio/
*.wav
*.mp3
uploaded_audio/

# --- Logs ---
*.log
